---
import Default from '@astrojs/starlight/components/Hero.astro';
---

<Default {...Astro.props}><slot /></Default>

<script>
  // Inject Living Circuit SVG background into .content-panel (full-bleed)
  const container = document.querySelector('[data-has-hero] .content-panel');
  if (container) {
    const bg = document.createElement('div');
    bg.className = 'circuit-bg';
    bg.innerHTML = `<svg viewBox="0 0 1200 700" preserveAspectRatio="xMidYMid slice" class="circuit-mask">
      <!-- Main traces -->
      <path class="trace" d="M60,120 V260 H180 V400 H100 V540 H220 V620"/>
      <path class="trace" d="M300,50 H420 V180 H340 V320 H480 V480 H380 V600"/>
      <path class="trace" d="M550,80 V220 H680 V120 H780 V300 H700 V450 H820 V580"/>
      <path class="trace" d="M950,60 H1080 V200 H1000 V360 H1120 V520 H1020 V650"/>
      <path class="trace" d="M150,350 H280 V200 H400 V350 H520 V500 H650 V350 H780 V500 H920 V340 H1060"/>
      <!-- Branch stubs -->
      <path class="trace" d="M180,260 H260 V210"/>
      <path class="trace" d="M680,220 V290 H740"/>
      <path class="trace" d="M1080,200 H1150 V260"/>
      <path class="trace" d="M480,480 V540 H540"/>
      <!-- Pulses -->
      <path class="pulse" d="M60,120 V260 H180 V400 H100 V540 H220 V620"/>
      <path class="pulse" d="M300,50 H420 V180 H340 V320 H480 V480 H380 V600"/>
      <path class="pulse" d="M550,80 V220 H680 V120 H780 V300 H700 V450 H820 V580"/>
      <path class="pulse" d="M950,60 H1080 V200 H1000 V360 H1120 V520 H1020 V650"/>
      <path class="pulse" d="M150,350 H280 V200 H400 V350 H520 V500 H650 V350 H780 V500 H920 V340 H1060"/>
      <!-- Solder pads -->
      <circle class="pad" cx="180" cy="260" r="4"/>
      <circle class="pad" cx="180" cy="400" r="3.5"/>
      <circle class="pad" cx="220" cy="540" r="4"/>
      <circle class="pad" cx="420" cy="180" r="4"/>
      <circle class="pad" cx="340" cy="320" r="3.5"/>
      <circle class="pad" cx="480" cy="480" r="4"/>
      <circle class="pad" cx="680" cy="220" r="4"/>
      <circle class="pad" cx="780" cy="300" r="3.5"/>
      <circle class="pad" cx="700" cy="450" r="4"/>
      <circle class="pad" cx="820" cy="580" r="3.5"/>
      <circle class="pad" cx="1080" cy="200" r="4"/>
      <circle class="pad" cx="1000" cy="360" r="4"/>
      <circle class="pad" cx="1120" cy="520" r="3.5"/>
      <circle class="pad" cx="280" cy="200" r="3.5"/>
      <circle class="pad" cx="520" cy="500" r="4"/>
      <circle class="pad" cx="650" cy="350" r="4"/>
      <circle class="pad" cx="920" cy="340" r="3.5"/>
    </svg>`;
    container.insertBefore(bg, container.firstChild);
  }
</script>
